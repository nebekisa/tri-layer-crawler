{
  "dashboard": {
    "title": "Tri-Layer Intelligence Crawler",
    "panels": [
      {
        "title": "Crawl Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(crawler_items_total[5m])",
            "legendFormat": "Items/sec"
          }
        ]
      },
      {
        "title": "Sentiment Distribution",
        "type": "piechart",
        "targets": [
          {
            "expr": "sentiment_positive_total",
            "legendFormat": "Positive"
          },
          {
            "expr": "sentiment_negative_total",
            "legendFormat": "Negative"
          },
          {
            "expr": "sentiment_neutral_total",
            "legendFormat": "Neutral"
          }
        ]
      },
      {
        "title": "Processing Time",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.5, rate(analysis_duration_seconds_bucket[5m]))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(analysis_duration_seconds_bucket[5m]))",
            "legendFormat": "p95"
          }
        ]
      },
      {
        "title": "Error Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(crawler_errors_total[5m]) / rate(crawler_requests_total[5m])",
            "legendFormat": "Error Rate"
          }
        ]
      },
      {
        "title": "Active Crawlers",
        "type": "gauge",
        "targets": [
          {
            "expr": "crawler_active_workers",
            "legendFormat": "Workers"
          }
        ]
      }
    ],
    "refresh": "10s",
    "time": {
      "from": "now-1h",
      "to": "now"
    }
  }
}