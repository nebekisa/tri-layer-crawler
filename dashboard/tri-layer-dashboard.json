{
  "dashboard": {
    "title": "Tri-Layer Crawler",
    "uid": "tri-layer-main",
    "panels": [
      {
        "id": 1,
        "title": "Total Items",
        "type": "stat",
        "targets": [{"format": "table", "rawSql": "SELECT COUNT(*) as value FROM crawled_items", "refId": "A"}],
        "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4}
      },
      {
        "id": 2,
        "title": "Unique Domains",
        "type": "stat",
        "targets": [{"format": "table", "rawSql": "SELECT COUNT(DISTINCT domain) as value FROM crawled_items", "refId": "A"}],
        "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4}
      },
      {
        "id": 3,
        "title": "Total Entities",
        "type": "stat",
        "targets": [{"format": "table", "rawSql": "SELECT COUNT(*) as value FROM extracted_entities", "refId": "A"}],
        "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4}
      },
      {
        "id": 4,
        "title": "Avg Sentiment",
        "type": "stat",
        "targets": [{"format": "table", "rawSql": "SELECT ROUND(AVG(sentiment_polarity)::numeric, 2) as value FROM analysis_results", "refId": "A"}],
        "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4}
      },
      {
        "id": 5,
        "title": "Recent Crawled Items",
        "type": "table",
        "targets": [{"format": "table", "rawSql": "SELECT id, url, title, domain, status_code, crawled_at FROM crawled_items ORDER BY crawled_at DESC LIMIT 20", "refId": "A"}],
        "gridPos": {"x": 0, "y": 4, "w": 12, "h": 10}
      },
      {
        "id": 6,
        "title": "Domain Distribution",
        "type": "piechart",
        "targets": [{"format": "table", "rawSql": "SELECT domain, COUNT(*) as value FROM crawled_items GROUP BY domain", "refId": "A"}],
        "gridPos": {"x": 12, "y": 4, "w": 12, "h": 10}
      },
      {
        "id": 7,
        "title": "Entities by Type",
        "type": "bargauge",
        "targets": [{"format": "table", "rawSql": "SELECT entity_type, COUNT(*) as value FROM extracted_entities GROUP BY entity_type ORDER BY value DESC LIMIT 10", "refId": "A"}],
        "gridPos": {"x": 0, "y": 14, "w": 12, "h": 8}
      },
      {
        "id": 8,
        "title": "Top Keywords",
        "type": "table",
        "targets": [{"format": "table", "rawSql": "SELECT keyword, SUM(score) as total_score FROM extracted_keywords GROUP BY keyword ORDER BY total_score DESC LIMIT 15", "refId": "A"}],
        "gridPos": {"x": 12, "y": 14, "w": 12, "h": 8}
      }
    ],
    "refresh": "30s",
    "time": {"from": "now-7d", "to": "now"}
  },
  "overwrite": true
}
