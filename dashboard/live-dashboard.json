{
  "dashboard": {
    "title": "Tri-Layer Crawler - LIVE DATA",
    "uid": "tri-layer-live",
    "refresh": "10s",
    "time": {"from": "now-15m", "to": "now"},
    "panels": [
      {
        "id": 1,
        "title": "?? Total Items Crawled",
        "type": "stat",
        "targets": [{"expr": "crawler_items_total", "format": "table"}],
        "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
        "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}]}}}
      },
      {
        "id": 2,
        "title": "?? Prometheus Status",
        "type": "stat",
        "targets": [{"expr": "up{job=\"api\"}", "format": "table"}],
        "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
        "fieldConfig": {"defaults": {"mappings": [{"type": "value", "value": "1", "text": "? UP"}], "thresholds": {"steps": [{"color": "green", "value": 1}]}}}
      },
      {
        "id": 3,
        "title": "?? Queue Pending",
        "type": "stat",
        "targets": [{"expr": "crawler_queue_pending", "format": "table"}],
        "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4}
      },
      {
        "id": 4,
        "title": "? Success Rate",
        "type": "stat",
        "targets": [{"expr": "sum(crawler_urls_total{status=\"success\"}) / sum(crawler_urls_total) * 100", "format": "table"}],
        "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
        "fieldConfig": {"defaults": {"unit": "percent", "max": 100}}
      },
      {
        "id": 5,
        "title": "?? Items Growth Over Time",
        "type": "timeseries",
        "targets": [{"expr": "crawler_items_total", "legendFormat": "Total Items"}],
        "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
        "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"fillOpacity": 20, "lineWidth": 2}}}
      },
      {
        "id": 6,
        "title": "??? URLs Crawled Over Time",
        "type": "timeseries",
        "targets": [{"expr": "increase(crawler_urls_total[5m])", "legendFormat": "URLs"}],
        "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8}
      },
      {
        "id": 7,
        "title": "??? Top Domains",
        "type": "bargauge",
        "targets": [{"expr": "sum by(domain) (crawler_urls_total)", "legendFormat": "{{domain}}"}],
        "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8}
      },
      {
        "id": 8,
        "title": "?? Sentiment Distribution",
        "type": "piechart",
        "targets": [
          {"expr": "sentiment_positive_total", "legendFormat": "Positive"},
          {"expr": "sentiment_neutral_total", "legendFormat": "Neutral"},
          {"expr": "sentiment_negative_total", "legendFormat": "Negative"}
        ],
        "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
        "fieldConfig": {"defaults": {"custom": {"pieType": "donut"}}}
      },
      {
        "id": 9,
        "title": "?? Recent Crawls (Table)",
        "type": "table",
        "targets": [{"expr": "crawler_urls_total", "format": "table", "legendFormat": "{{domain}}"}],
        "gridPos": {"x": 0, "y": 20, "w": 24, "h": 6}
      }
    ]
  },
  "overwrite": true
}
