{
  "dashboard": {
    "title": "Tri-Layer Crawler - Working",
    "uid": "tri-layer-working",
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "Total Items Crawled",
        "type": "stat",
        "targets": [{"expr": "crawler_items_total", "format": "time_series"}],
        "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4}
      },
      {
        "id": 2,
        "title": "API Status",
        "type": "stat",
        "targets": [{"expr": "up{job=\"api\"}", "format": "time_series"}],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"type": "value", "value": "1", "text": "UP"},
              {"type": "value", "value": "0", "text": "DOWN"}
            ],
            "color": {"mode": "thresholds"},
            "thresholds": {"steps": [{"value": 0, "color": "red"}, {"value": 1, "color": "green"}]}
          }
        },
        "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4}
      },
      {
        "id": 3,
        "title": "Queue Pending",
        "type": "stat",
        "targets": [{"expr": "crawler_queue_pending", "format": "time_series"}],
        "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4}
      },
      {
        "id": 4,
        "title": "Crawl Success Rate",
        "type": "stat",
        "targets": [{
          "expr": "sum(rate(crawler_urls_total{status=\"success\"}[5m])) / sum(rate(crawler_urls_total[5m])) * 100",
          "format": "time_series"
        }],
        "fieldConfig": {"defaults": {"unit": "percent", "max": 100}},
        "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4}
      },
      {
        "id": 5,
        "title": "Items Growth",
        "type": "timeseries",
        "targets": [{"expr": "crawler_items_total", "legendFormat": "Total Items"}],
        "gridPos": {"x": 0, "y": 4, "w": 24, "h": 10}
      }
    ],
    "time": {"from": "now-1h", "to": "now"}
  }
}
