{
  "dashboard": {
    "title": "Tri-Layer Crawler - LIVE",
    "uid": "tri-layer-live-v2",
    "refresh": "10s",
    "time": {"from": "now-15m", "to": "now"},
    "panels": [
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "id": 1,
        "title": "?? Total Items Crawled",
        "type": "stat",
        "targets": [{"expr": "crawler_items_total", "format": "table"}],
        "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
        "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}]}}}
      },
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "id": 2,
        "title": "?? API Status",
        "type": "stat",
        "targets": [{"expr": "up", "format": "table"}],
        "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
        "fieldConfig": {"defaults": {"mappings": [{"type": "value", "value": "1", "text": "? UP"}], "thresholds": {"steps": [{"color": "green", "value": 1}]}}}
      },
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "id": 3,
        "title": "?? Queue Pending",
        "type": "stat",
        "targets": [{"expr": "crawler_queue_pending", "format": "table"}],
        "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4}
      },
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "id": 4,
        "title": "?? Items Growth",
        "type": "timeseries",
        "targets": [{"expr": "crawler_items_total", "legendFormat": "Total Items"}],
        "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8}
      },
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "id": 5,
        "title": "??? URLs Crawled",
        "type": "timeseries",
        "targets": [{"expr": "rate(crawler_urls_total[1m])", "legendFormat": "Crawl Rate"}],
        "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8}
      },
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "id": 6,
        "title": "??? Top Domains",
        "type": "bargauge",
        "targets": [{"expr": "sum by(domain) (crawler_urls_total)", "legendFormat": "{{domain}}"}],
        "gridPos": {"x": 0, "y": 12, "w": 24, "h": 8}
      }
    ]
  },
  "overwrite": true
}
