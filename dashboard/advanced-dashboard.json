{
  "dashboard": {
    "title": "Tri-Layer Intelligence Crawler - Advanced",
    "uid": "tri-layer-advanced",
    "refresh": "10s",
    "time": {"from": "now-6h", "to": "now"},
    "timepicker": {"refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]},
    "tags": ["crawler", "production", "ai"],
    "panels": [
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "id": 100,
        "title": "?? TOTAL ITEMS",
        "type": "stat",
        "targets": [{"expr": "crawler_items_total", "format": "table"}],
        "gridPos": {"x": 0, "y": 0, "w": 4, "h": 3},
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {"steps": [{"color": "blue", "value": 0}]},
            "unit": "short"
          }
        }
      },
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "id": 101,
        "title": "?? API STATUS",
        "type": "stat",
        "targets": [{"expr": "up{job=\"api\"}", "format": "table"}],
        "gridPos": {"x": 4, "y": 0, "w": 4, "h": 3},
        "fieldConfig": {
          "defaults": {
            "mappings": [{"type": "value", "value": "1", "text": "? ONLINE"}],
            "color": {"mode": "thresholds"},
            "thresholds": {"steps": [{"color": "green", "value": 1}, {"color": "red", "value": 0}]}
          }
        }
      },
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "id": 102,
        "title": "?? QUEUE PENDING",
        "type": "stat",
        "targets": [{"expr": "crawler_queue_pending", "format": "table"}],
        "gridPos": {"x": 8, "y": 0, "w": 4, "h": 3},
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 10}, {"color": "red", "value": 50}]}
          }
        }
      },
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "id": 103,
        "title": "? SUCCESS RATE",
        "type": "stat",
        "targets": [{"expr": "sum(crawler_urls_total{status=\"success\"}) / sum(crawler_urls_total) * 100", "format": "table"}],
        "gridPos": {"x": 12, "y": 0, "w": 4, "h": 3},
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "max": 100,
            "color": {"mode": "thresholds"},
            "thresholds": {"steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 95}, {"color": "green", "value": 99}]}
          }
        }
      },
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "id": 104,
        "title": "??? UNIQUE DOMAINS",
        "type": "stat",
        "targets": [{"expr": "count(count by(domain) (crawler_urls_total))", "format": "table"}],
        "gridPos": {"x": 16, "y": 0, "w": 4, "h": 3}
      },
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "id": 105,
        "title": "??? CRAWL RATE (req/sec)",
        "type": "stat",
        "targets": [{"expr": "round(rate(crawler_urls_total[1m]), 2)", "format": "table"}],
        "gridPos": {"x": 20, "y": 0, "w": 4, "h": 3},
        "fieldConfig": {"defaults": {"unit": "reqps"}}
      },
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "id": 200,
        "title": "?? ITEMS GROWTH OVER TIME",
        "type": "timeseries",
        "targets": [
          {"expr": "crawler_items_total", "legendFormat": "Total Items", "refId": "A"},
          {"expr": "increase(crawler_items_total[1h])", "legendFormat": "Hourly Growth", "refId": "B"}
        ],
        "gridPos": {"x": 0, "y": 3, "w": 12, "h": 8},
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {"fillOpacity": 20, "lineWidth": 2, "showPoints": "never"},
            "unit": "short"
          }
        }
      },
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "id": 201,
        "title": "?? CRAWL RATE BY DOMAIN",
        "type": "timeseries",
        "targets": [{"expr": "sum by(domain) (rate(crawler_urls_total[5m]))", "legendFormat": "{{domain}}"}],
        "gridPos": {"x": 12, "y": 3, "w": 12, "h": 8},
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {"fillOpacity": 15, "lineWidth": 2, "stacking": {"mode": "none"}},
            "unit": "reqps"
          }
        }
      },
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "id": 300,
        "title": "??? TOP DOMAINS (BAR CHART)",
        "type": "bargauge",
        "targets": [{"expr": "topk(10, sum by(domain) (crawler_urls_total))", "legendFormat": "{{domain}}"}],
        "gridPos": {"x": 0, "y": 11, "w": 8, "h": 6},
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "short"
          }
        }
      },
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "id": 301,
        "title": "?? SENTIMENT DISTRIBUTION",
        "type": "piechart",
        "targets": [
          {"expr": "sentiment_positive_total", "legendFormat": "Positive", "refId": "A"},
          {"expr": "sentiment_neutral_total", "legendFormat": "Neutral", "refId": "B"},
          {"expr": "sentiment_negative_total", "legendFormat": "Negative", "refId": "C"}
        ],
        "gridPos": {"x": 8, "y": 11, "w": 8, "h": 6},
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "fixed"},
            "custom": {"pieType": "donut", "displayLabels": ["percent", "name"]}
          },
          "overrides": [
            {"matcher": {"id": "byName", "options": "Positive"}, "properties": [{"id": "color", "value": "green"}]},
            {"matcher": {"id": "byName", "options": "Neutral"}, "properties": [{"id": "color", "value": "orange"}]},
            {"matcher": {"id": "byName", "options": "Negative"}, "properties": [{"id": "color", "value": "red"}]}
          ]
        }
      },
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "id": 302,
        "title": "?? STATUS CODE DISTRIBUTION",
        "type": "piechart",
        "targets": [{"expr": "sum by(status) (crawler_urls_total)", "legendFormat": "{{status}}"}],
        "gridPos": {"x": 16, "y": 11, "w": 8, "h": 6},
        "fieldConfig": {
          "defaults": {
            "custom": {"pieType": "pie", "displayLabels": ["percent"]}
          },
          "overrides": [
            {"matcher": {"id": "byName", "options": "success"}, "properties": [{"id": "color", "value": "green"}]},
            {"matcher": {"id": "byName", "options": "failure"}, "properties": [{"id": "color", "value": "red"}]}
          ]
        }
      },
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "id": 400,
        "title": "?? RECENT CRAWL ACTIVITY",
        "type": "table",
        "targets": [{"expr": "crawler_urls_total", "format": "table", "legendFormat": "{{domain}}"}],
        "gridPos": {"x": 0, "y": 17, "w": 24, "h": 6},
        "fieldConfig": {
          "defaults": {
            "custom": {"align": "auto", "displayMode": "auto"},
            "mappings": [],
            "thresholds": {"steps": [{"color": "green", "value": null}]}
          },
          "overrides": [
            {"matcher": {"id": "byName", "options": "Value"}, "properties": [{"id": "custom.width", "value": 150}]}
          ]
        }
      }
    ]
  },
  "overwrite": true
}
